{
  "name": "frida",
  "version": "1.0.0",
  "description": "A modern, intuitive, and beautiful spaced repetition flashcard app",
  "main": "main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:frontend": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k -r \"npm run dev:frontend\" \"electron .\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^0.395.0",
    "papaparse": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "build": {
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico"
    },
    "mac": {
      "icon": "assets/icon.icns"
    }
